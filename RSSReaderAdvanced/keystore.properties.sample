# Copy this file to "keystore.properties" (same folder) and fill in your
# upload-key details. When that file exists, release builds (bundleFreeRelease
# / bundleProRelease) are signed automatically. Never commit the real file.
#
# Create a keystore once with:
#   keytool -genkey -v -keystore upload-key.jks -keyalg RSA -keysize 2048 \
#           -validity 10000 -alias upload
#
storeFile=../upload-key.jks
storePassword=yourStorePassword
keyAlias=upload
keyPassword=yourKeyPassword
