<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_close"
            app:title="@string/title_settings" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <TextView
                style="@style/SettingsHeader"
                android:text="@string/setting_storage_header" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_store_local"
                style="@style/SettingsSwitch"
                android:text="@string/setting_store_local" />

            <TextView
                style="@style/SettingsSub"
                android:text="@string/setting_store_local_sub" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_show_images"
                style="@style/SettingsSwitch"
                android:text="@string/setting_show_images" />

            <TextView
                style="@style/SettingsSub"
                android:text="@string/setting_show_images_sub" />

            <View style="@style/SettingsDivider" />

            <TextView
                style="@style/SettingsHeader"
                android:text="@string/setting_refresh_header" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_auto_refresh"
                style="@style/SettingsSwitch"
                android:text="@string/setting_auto_refresh" />

            <TextView
                style="@style/SettingsSub"
                android:text="@string/setting_auto_refresh_sub" />

            <LinearLayout
                android:id="@+id/row_interval"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/setting_interval"
                    android:textAppearance="?attr/textAppearanceBodyMedium" />

                <androidx.appcompat.widget.AppCompatSpinner
                    android:id="@+id/spinner_interval"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_push"
                style="@style/SettingsSwitch"
                android:text="@string/setting_push" />

            <TextView
                style="@style/SettingsSub"
                android:text="@string/setting_push_sub" />

            <View style="@style/SettingsDivider" />

            <TextView
                android:id="@+id/row_about"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:padding="16dp"
                android:text="@string/setting_about"
                android:textAppearance="?attr/textAppearanceBodyLarge" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
